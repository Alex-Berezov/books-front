# ============================================
# Bibliaris Frontend — Production Environment
# ============================================

# Build-time variables (public, baked into the JS bundle)
NEXT_PUBLIC_API_BASE_URL=https://api.bibliaris.com/api
NEXT_PUBLIC_SITE_URL=https://bibliaris.com
NEXT_PUBLIC_DEFAULT_LANG=en

# Runtime variables (server-side only, loaded via env_file)
NEXTAUTH_URL=https://bibliaris.com
NEXTAUTH_SECRET=replace-me-with-a-strong-random-string

# Notes:
# - NEXT_PUBLIC_* vars are injected at build time via Docker build-args in CI.
# - NEXTAUTH_SECRET must be a real random value in production.
# - Copy this file to /opt/bibliaris-frontend/app/.env.production on the server.
# - NEVER commit the real .env.production to the repository.
